# ---- GitHub (live projects data) ----
# Fine-grained PAT scoped to thensmt/*
# Permissions: Contents: Read, Metadata: Read
GITHUB_TOKEN=

# Optional: force fixture mode for offline dev
# NSMT_USE_FIXTURE=1

# ---- Auth.js v5 — Google SSO (nsmtsports.com-only) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Needed when the app runs behind a proxy (Vercel, localhost over http, etc.)
AUTH_TRUST_HOST=true
